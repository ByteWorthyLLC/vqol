{
  "name": "vqol",
  "private": true,
  "version": "0.1.0-pre",
  "type": "module",
  "description": "Patient-owned VEINES-QOL/Sym tracker — static, white-labelable, viral OSS PWA for vein/vascular practices.",
  "license": "MIT",
  "homepage": "https://github.com/ByteWorthyLLC/vqol",
  "repository": {
    "type": "git",
    "url": "https://github.com/ByteWorthyLLC/vqol.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "npm run check:types && npm run check:contrast && npm run check:translations",
    "check:types": "svelte-check --tsconfig ./tsconfig.json",
    "check:contrast": "node --experimental-strip-types scripts/validate-contrast.ts",
    "check:translations": "node --experimental-strip-types scripts/validate-translations.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.4",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "idb": "^8.0.1"
  }
}
